generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Mahasiswa {
  id         Int        @id @default(autoincrement())
  npm        String     @unique
  password   String
  fotoKtmUrl String
  createdAt  DateTime   @default(now())
  isVerified Boolean    @default(false)
  nama       String     @default("")
  aspirasi   Aspirasi[]
}

model Aspirasi {
  id          Int        @id @default(autoincrement())
  judul       String
  kategori    String
  deskripsi   String
  isAnonymous Boolean    @default(false)
  status      String     @default("Diproses")
  createdAt   DateTime   @default(now())
  mahasiswaId Int?
  isVisible   Boolean    @default(false)
  mahasiswa   Mahasiswa? @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)
}

model Berita {
  id        Int      @id @default(autoincrement())
  judul     String
  narasi    String
  fotoUrl   String
  createdAt DateTime @default(now())
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Pengurus {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  nama      String
  jabatan   String
  fotoUrl   String?
  detail    String
  updatedAt DateTime @updatedAt
}
